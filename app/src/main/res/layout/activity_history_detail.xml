<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vanilla_cream"
    android:padding="16dp"
    android:fitsSystemWindows="true">

    <TextView
        android:id="@+id/tvDetailTitle"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/blue_slate"
        android:text="Purchase Detail"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView android:id="@+id/tvDetailName"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:textSize="18sp" android:textColor="@color/blue_slate" android:padding="12dp"
        android:background="@color/vanilla_cream" android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvDetailTitle"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <TextView android:id="@+id/tvDetailQty"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:textSize="18sp" android:textColor="@color/blue_slate" android:padding="12dp"
        android:background="@color/vanilla_cream" android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvDetailName"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <TextView android:id="@+id/tvDetailTotal"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:textSize="18sp" android:textColor="@color/blue_slate" android:padding="12dp"
        android:background="@color/vanilla_cream" android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvDetailQty"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <TextView android:id="@+id/tvDetailDate"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:textSize="18sp" android:textColor="@color/blue_slate" android:padding="12dp"
        android:background="@color/vanilla_cream" android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvDetailTotal"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <Button android:id="@+id/btnBack"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Back" android:textColor="@color/blue_slate"
        android:background="@color/powder_blush" android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
